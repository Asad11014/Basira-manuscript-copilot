# ─────────────────────────────────────────────────────────────────────────────
# Basira — environment configuration
# Copy to `.env` and fill in. NEVER commit a real `.env`. (§14)
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=development
API_PORT=4000
WEB_PORT=5173
# Public URL of the API, used by the web client and for cookie/CORS config.
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173

# --- Database (PostgreSQL 16) ---
# Docker maps Postgres to host port 5433 (avoids clashing with a local 5432).
DATABASE_URL=postgresql://basira:basira@localhost:5433/basira?schema=public

# --- Redis + BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Object storage ---
# minio | local | s3
STORAGE_DRIVER=minio
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=basira
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# When STORAGE_DRIVER=local, files are written here:
LOCAL_STORAGE_DIR=./.storage

# --- Auth ---
# Generate a long random string, e.g. `openssl rand -base64 48`
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=basira_token
COOKIE_SECURE=false
# Cross-site deploys (web + API on different hosts) need 'none' (forces Secure).
COOKIE_SAMESITE=lax
# Run the BullMQ worker in the API process (set 'true' for a single-service deploy).
RUN_INLINE_WORKER=

# --- Model provider (default LLM adapters) ---
# The default transcribe/translate/ner adapters call a vision-capable LLM.
MODEL_PROVIDER=anthropic
MODEL_PROVIDER_API_KEY=
# Vision-capable model for transcription; text model for translation/NER.
MODEL_VISION_NAME=claude-opus-4-8
MODEL_TEXT_NAME=claude-opus-4-8

# --- Adapter selection (resolved by the registry, §8) ---
# Use TRANSCRIBE_ADAPTER=demo and TRANSLATE_ADAPTER=demo for local demos
# without Kraken or an LLM key.
TRANSCRIBE_ADAPTER=llm-vision
TRANSLATE_ADAPTER=llm
NER_ADAPTER=llm

# --- Kraken HTR (free, local transcription) ---
# Set TRANSCRIBE_ADAPTER=kraken to use the open-source Kraken engine instead of
# the LLM. Start the sidecar: `docker compose --profile kraken up -d kraken`.
KRAKEN_URL=http://localhost:8500
# Recognition model auto-downloaded on first boot (OpenITI printed Arabic).
KRAKEN_MODEL_DOI=10.5281/zenodo.7050270
KRAKEN_MODEL_NAME=kraken-openiti-arabic
KRAKEN_MODEL_VERSION=OpenITI printed Arabic / 10.5281/zenodo.7050270
# box = light, best for printed/clean (works at ~3.8GB Docker).
# baseline = neural segmenter for complex handwriting (give Docker ~6-8GB).
KRAKEN_SEG_MODE=box
KRAKEN_BASE_DIR=R

# --- Licence gating (non-commercial Muharaf model is demo-user-only) ---
DEMO_USER_EMAIL=demo@basira.test
# Adapters only the demo user may invoke; their outputs are excluded from the
# ground-truth/training export so non-commercial data can't contaminate it.
RESTRICTED_TRANSCRIBE_ADAPTERS=kraken-muharaf
# After training + installing the Muharaf model, set this to kraken-muharaf so
# the demo user's transcriptions use it. Leave empty until the model exists.
DEMO_TRANSCRIBE_ADAPTER=

# --- Limits / defaults ---
MAX_UPLOAD_MB=100
DEFAULT_TARGET_LANG=en
